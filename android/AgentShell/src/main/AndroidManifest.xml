<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.agentos.shell">

    <!-- Agent needs network to reach the LLM API. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Daily spicy-take notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- SlyOS-styled lock-screen wallpaper. -->
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Keep the screen on while the operate agent runs (long / overnight mission execution). -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Telegram bot runs as a foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- Live-location sharing "until I'm home" runs as a location foreground service. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- The AI call agent runs as a microphone foreground service while talking to a caller. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <!-- Floating nav panel that draws over other apps (user-granted "Display over other apps"). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <!-- Triage notifications for the Now / People layers (user grants in Settings). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Live "Look" camera (point-and-identify). -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Attachments: list the photos people sent you (WhatsApp, Telegram, screenshots) so HomeAI can act on them. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-feature android:name="android.hardware.camera.any" android:required="false"/>
    <!-- Calendar awareness + the ability to block time. -->
    <uses-permission android:name="android.permission.READ_CALENDAR"/>
    <uses-permission android:name="android.permission.WRITE_CALENDAR"/>
    <!-- Contacts + SMS so the agent can text people directly. -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.SEND_SMS"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"/>
    <!-- Let Cowork run real shell commands in the user's Termux (build & run apps locally). -->
    <uses-permission android:name="com.termux.permission.RUN_COMMAND"/>

    <application
        android:label="SlyOS"
        android:theme="@style/Theme.SlyOS"
        android:supportsRtl="true"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"><!-- P0.4: keep the brain + keys off adb backup / cloud backup -->

        <!-- The launcher: registering HOME is what replaces the One UI launcher. -->
        <activity
            android:name=".ShellActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:excludeFromRecents="true"
            android:configChanges="orientation|keyboardHidden|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Catches the Google OAuth redirect (reversed-client-id scheme) back into the app. -->
        <activity
            android:name=".GoogleAuthRedirectActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <!-- Match on scheme only (reversed client ID); path matching without a host is unreliable. -->
                <data android:scheme="${googleRedirectScheme}"/>
            </intent-filter>
        </activity>

        <!-- Device Owner entry point (granted later via adb dpm; see scripts/). -->
        <receiver
            android:name=".AdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin"/>
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED"/>
            </intent-filter>
        </receiver>

        <!-- Telegram bot brain (foreground service). -->
        <service
            android:name=".TelegramService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Persistent floating nav panel that overlays other apps. -->
        <service
            android:name=".OverlayNavService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Live-location sharing "until I'm home" (foreground service, location type). -->
        <service
            android:name=".LiveLocationService"
            android:exported="false"
            android:foregroundServiceType="location"/>

        <!-- On-device AI call screening (user grants the call-screening role). -->
        <service
            android:name=".SlyCallScreeningService"
            android:permission="android.permission.BIND_SCREENING_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService"/>
            </intent-filter>
        </service>

        <!-- The AI call agent: talks to a caller after an auto-answered WhatsApp/VoIP call. -->
        <service
            android:name=".CallAgentService"
            android:exported="false"
            android:foregroundServiceType="microphone"/>

        <!-- Chess Coach overlay (board hints). Plain started service; kept alive by its overlay windows. -->
        <service
            android:name=".ChessCoachService"
            android:exported="false"/>

        <!-- Lets the camera write full-res photos we can read back for posts. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.agentos.shell.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- Feeds Now / People with triaged notifications (user-granted). -->
        <service
            android:name=".AgentNotificationListener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!-- Reads on-screen text into searchable memory for recall (user-granted in Settings). -->
        <service
            android:name=".InteractionLogService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config"/>
        </service>

        <!-- Fires timed reminders ("remind me in 20 min to…") as notifications. -->
        <receiver android:name=".ReminderReceiver" android:exported="false"/>

        <!-- STOP button for the action layer ("SlyOS is controlling your screen"). -->
        <receiver android:name=".StopActionReceiver" android:exported="false"/>
    </application>
</manifest>
