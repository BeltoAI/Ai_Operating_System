{
  "$meta": {
    "name": "AgentOS Design Tokens",
    "version": "0.1.0",
    "description": "Minimal Apple-like. Warm ivory, near-black type, one subtle orange accent."
  },
  "color": {
    "bg": "#F4EFE6",
    "bg-elevated": "#FBF8F2",
    "ink": "#1A1714",
    "ink-soft": "#5C544B",
    "ink-faint": "#9A9085",
    "accent": "#E8642C",
    "accent-soft": "#F2C7AE",
    "hairline": "#E2DACB",
    "danger": "#B23A2E"
  },
  "font": {
    "wordmark": "'Caveat', 'Segoe Script', cursive",
    "ui": "-apple-system, 'SF Pro Text', 'Inter', system-ui, sans-serif",
    "weight-light": 300,
    "weight-regular": 400,
    "weight-medium": 500
  },
  "size": {
    "wordmark": 30,
    "time": 64,
    "prompt": 26,
    "body": 17,
    "small": 14,
    "caption": 12
  },
  "space": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 40, "xxl": 72 },
  "radius": { "sm": 8, "md": 16, "lg": 28, "pill": 999 },
  "motion": {
    "calm": "600ms cubic-bezier(0.22, 1, 0.36, 1)",
    "pulse": "2400ms ease-in-out infinite"
  }
}
